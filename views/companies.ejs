<%- include('layout/header') %>

<h2 class="fw-bold tracking-tight mb-4 text-3xl">All Companies</h2>
<p class="text-secondary mb-5">Browse all companies available in the event and view their prospectuses.</p>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
  <% companies.forEach(company => { %>
    <div class="col">
      <div class="card h-100 shadow-sm border-0 rounded-4 transition-all hover-shadow">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-start mb-3">
            <h5 class="fw-bold mb-0 text-xl"><%= company.name %></h5>
            
            <% if (company.status === 'Available') { %>
              <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2 border border-success border-opacity-25">Available</span>
            <% } else if (company.status === 'Owned by You') { %>
              <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2 border border-primary border-opacity-25">Owned by You</span>
            <% } else { %>
              <span class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill px-3 py-2 border border-secondary border-opacity-25">Sold</span>
            <% } %>
          </div>
          
          <p class="text-muted text-sm mb-4" style="min-height: 48px;"><%= company.description || 'No description provided.' %></p>
          
          <% if (company.pdf_url) { %>
            <div class="mt-auto">
              <a href="<%= company.pdf_url %>" target="_blank" class="btn btn-light w-100 rounded-3 text-start shadow-sm d-flex align-items-center">
                <div class="bg-danger text-white rounded p-2 me-3 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                  PDF
                </div>
                <div class="fw-semibold text-dark">View Prospectus</div>
              </a>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  <% }) %>
</div>

<% if (companies.length === 0) { %>
  <div class="alert alert-light text-center py-5 shadow-sm rounded-4 border-0">
    <h4 class="text-muted fw-semibold">No companies available yet.</h4>
  </div>
<% } %>

<style>
  .transition-all { transition: all 0.3s ease; }
  .hover-shadow:hover { transform: translateY(-3px); box-shadow: 0 8px 15px rgba(0,0,0,0.05) !important; }
</style>

<%- include('layout/footer') %>
