<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bid to Build</title>
  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Custom CSS -->
  <link rel="stylesheet" href="/css/style.css">
  <style>
    body {
      background-color: #f8f9fa;
      font-family: 'Inter', sans-serif;
    }
  </style>
</head>
<body class="antialiased text-gray-800">

<nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4 shadow-sm">
  <div class="container">
    <a class="navbar-brand fw-bold tracking-wider me-auto" href="/">Bid to Build</a>
    <% if (user) { %>
      <div class="d-flex order-lg-last ms-3 align-items-center">
        <form action="/logout" method="POST" class="d-inline m-0 p-0">
          <button type="submit" class="btn btn-outline-danger btn-sm fw-semibold">Logout</button>
        </form>
      </div>
    <% } %>
    <button class="navbar-toggler ms-2" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav ms-auto">
        <% if (user) { %>
          <% if (user.role === 'admin') { %>
            <li class="nav-item">
              <a class="nav-link" href="/admin/dashboard">Admin Dashboard</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/admin/logs"><i class="bi bi-journal-text me-1"></i>Activity Logs</a>
            </li>
          <% } else { %>
            <li class="nav-item">
              <a class="nav-link" href="/team/dashboard">Team Dashboard</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/team/companies">Companies</a>
            </li>

          <% } %>
          <li class="nav-item">
            <a class="nav-link" href="/leaderboard">Leaderboard</a>
          </li>
        <% } else { %>
          <li class="nav-item">
            <a class="nav-link" href="/login">Login</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/leaderboard">Leaderboard</a>
          </li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>

<div class="container pb-5">
  <% if (errorMsg) { %>
    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
      <%= errorMsg %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% } %>
  <% if (successMsg) { %>
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
      <%= successMsg %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% } %>
