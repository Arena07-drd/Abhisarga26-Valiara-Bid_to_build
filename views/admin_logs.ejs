<%- include('layout/header') %>

<div class="row mb-4 align-items-center">
  <div class="col-md-6">
    <h1 class="fw-bold tracking-tight display-5">Activity Logs</h1>
    <p class="text-secondary">Complete audit trail of every action — with purse snapshots at each point.</p>
  </div>
  <div class="col-md-6 text-md-end">
    <a href="/admin/dashboard" class="btn btn-outline-dark rounded-pill fw-semibold px-4"><i class="bi bi-arrow-left me-2"></i>Back to Dashboard</a>
  </div>
</div>

<!-- Filter Bar -->
<div class="card border-0 shadow-sm rounded-4 mb-4">
  <div class="card-body p-3">
    <form method="GET" action="/admin/logs" class="row g-2 align-items-end">
      <div class="col-md-3">
        <label class="form-label text-sm fw-semibold text-muted">Filter by Action</label>
        <select name="action" class="form-select rounded-3">
          <option value="">All Actions</option>
          <option value="CREATE_USER" <%= filter_action === 'CREATE_USER' ? 'selected' : '' %>>Create User</option>
          <option value="ADD_COMPANY" <%= filter_action === 'ADD_COMPANY' ? 'selected' : '' %>>Add Company</option>
          <option value="ASSIGN_BID" <%= filter_action === 'ASSIGN_BID' ? 'selected' : '' %>>Assign Bid</option>
          <option value="PHASE_CHANGE" <%= filter_action === 'PHASE_CHANGE' ? 'selected' : '' %>>Phase Change</option>
          <option value="UPDATE_DEFAULT_PURSES" <%= filter_action === 'UPDATE_DEFAULT_PURSES' ? 'selected' : '' %>>Update Default Purses</option>
          <option value="UPDATE_TEAM_PURSE" <%= filter_action === 'UPDATE_TEAM_PURSE' ? 'selected' : '' %>>Update Team Purse</option>
          <option value="SET_LIVE_COMPANY" <%= filter_action === 'SET_LIVE_COMPANY' ? 'selected' : '' %>>Set Live Company</option>
          <option value="DELETE_TEAM" <%= filter_action === 'DELETE_TEAM' ? 'selected' : '' %>>Delete Team</option>
          <option value="DELETE_COMPANY" <%= filter_action === 'DELETE_COMPANY' ? 'selected' : '' %>>Delete Company</option>
          <option value="REVOKE_BID" <%= filter_action === 'REVOKE_BID' ? 'selected' : '' %>>Revoke Bid</option>
          <option value="PROPOSE_TRADE" <%= filter_action === 'PROPOSE_TRADE' ? 'selected' : '' %>>Propose Trade</option>
          <option value="ACCEPT_TRADE" <%= filter_action === 'ACCEPT_TRADE' ? 'selected' : '' %>>Accept Trade</option>
          <option value="REJECT_TRADE" <%= filter_action === 'REJECT_TRADE' ? 'selected' : '' %>>Reject Trade</option>
          <option value="RESET_ALL_DATA" <%= filter_action === 'RESET_ALL_DATA' ? 'selected' : '' %>>Reset All Data</option>
        </select>
      </div>
      <div class="col-md-3">
        <label class="form-label text-sm fw-semibold text-muted">Filter by Actor</label>
        <input type="text" name="actor" class="form-control rounded-3" placeholder="e.g. ADMIN or TEAM:Alpha" value="<%= filter_actor || '' %>">
      </div>
      <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100 rounded-3 fw-semibold">Filter</button>
      </div>
      <div class="col-md-2">
        <a href="/admin/logs" class="btn btn-outline-secondary w-100 rounded-3 fw-semibold">Clear</a>
      </div>
    </form>
  </div>
</div>

<div class="card border-0 shadow-sm rounded-4">
  <div class="table-responsive p-0">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-dark">
        <tr>
          <th class="ps-4" style="width:50px">#</th>
          <th style="width:170px">Timestamp</th>
          <th style="width:140px">Actor</th>
          <th style="width:160px">Action</th>
          <th>Details</th>
          <th>Purse Snapshot</th>
        </tr>
      </thead>
      <tbody>
        <% if (logs.length === 0) { %>
          <tr><td colspan="6" class="text-center text-muted py-5 fs-5">No activity logs found.</td></tr>
        <% } else { %>
          <% logs.forEach((log, i) => { %>
            <tr>
              <td class="ps-4 text-muted fw-bold"><%= log.id %></td>
              <td class="text-muted text-sm"><%= new Date(log.timestamp).toLocaleString() %></td>
              <td>
                <% if (log.actor === 'ADMIN') { %>
                  <span class="badge bg-danger px-3 py-2 rounded-pill"><i class="bi bi-shield-lock-fill me-1"></i>ADMIN</span>
                <% } else { %>
                  <span class="badge bg-primary px-3 py-2 rounded-pill"><i class="bi bi-people-fill me-1"></i><%= log.actor %></span>
                <% } %>
              </td>
              <td>
                <span class="badge 
                  <% if (log.action.includes('DELETE') || log.action === 'RESET_ALL_DATA') { %>bg-danger
                  <% } else if (log.action.includes('TRADE')) { %>bg-warning text-dark
                  <% } else if (log.action === 'PHASE_CHANGE') { %>bg-info text-dark
                  <% } else if (log.action.includes('UPDATE')) { %>bg-secondary
                  <% } else { %>bg-success
                  <% } %> px-3 py-2 rounded-pill fw-bold">
                  <%= log.action %>
                </span>
              </td>
              <td class="text-sm"><%= log.details %></td>
              <td>
                <% if (log.purse_snapshot) { %>
                  <code class="bg-light text-dark p-2 rounded-3 d-inline-block text-sm" style="max-width:350px; word-break:break-all;"><%= log.purse_snapshot %></code>
                <% } else { %>
                  <span class="text-muted">—</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<div class="text-center text-muted mt-3 mb-5">
  Showing <strong><%= logs.length %></strong> log entries (most recent first)
</div>

<%- include('layout/footer') %>
