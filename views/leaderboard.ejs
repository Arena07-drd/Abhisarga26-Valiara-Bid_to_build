<%- include('layout/header') %>

<div class="row mb-5 justify-content-center text-center">
  <div class="col-md-8">
    <h1 class="fw-bold tracking-tight display-4 text-gray-900 mb-3">Leaderboard</h1>
    <p class="text-secondary fs-5">Live rankings sorted by total score derived from portfolio performances.</p>
  </div>
</div>

<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="card shadow rounded-4 border-0 overflow-hidden">
      <% if (scores.length === 0) { %>
        <div class="card-body text-center py-5">
          <i class="bi bi-trophy text-muted display-1 mb-3"></i>
          <h4 class="text-muted fw-semibold">Scoring has not been calculated yet.</h4>
          <p class="mb-0">Check back after the admin triggers the scoring engine.</p>
        </div>
      <% } else { %>
        <table class="table table-hover align-middle mb-0">
          <thead class="bg-light">
            <tr>
              <th class="py-3 px-4 text-secondary fw-semibold border-bottom-0" style="width: 15%;"># Rank</th>
              <th class="py-3 px-4 text-secondary fw-semibold border-bottom-0">Team Name</th>
              <th class="py-3 px-4 text-secondary fw-semibold border-bottom-0 text-end">Total Score</th>
            </tr>
          </thead>
          <tbody>
            <% scores.forEach((score, index) => { %>
              <tr class="<%= index === 0 ? 'table-warning' : (index === 1 ? 'table-light' : (index === 2 ? 'table-secondary text-white' : '')) %>" style="<%= index === 2 ? 'background-color: #cd7f32 !important' : '' %>">
                <td class="py-4 px-4 fw-bold fs-5">
                  <% if (index === 0) { %> 🥇 1
                  <% } else if (index === 1) { %> 🥈 2
                  <% } else if (index === 2) { %> 🥉 3
                  <% } else { %> <%= index + 1 %> <% } %>
                </td>
                <td class="py-4 px-4 fw-semibold fs-5"><%= score.team_name %></td>
                <td class="py-4 px-4 text-end fw-bold fs-4 text-success"><%= score.total_score.toLocaleString(undefined, {minimumFractionDigits: 0, maximumFractionDigits: 2}) %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>
</div>

<%- include('layout/footer') %>
