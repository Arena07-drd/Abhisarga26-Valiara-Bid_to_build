<%- include('layout/header') %>

<style>
  body {
    background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);
    color: white;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
  .glass-panel {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.5);
  }
</style>

<div class="container d-flex justify-content-center align-items-center flex-grow-1" style="margin-top: -3rem;">
  <div class="row w-100 justify-content-center">
    <!-- Login Form -->
    <div class="col-md-5 col-lg-4">
      <div class="glass-panel p-5 text-center">
        <h2 class="mb-4 fw-bold tracking-tight">Access Portal</h2>
        
        <form action="/login" method="POST">
          <div class="form-floating mb-3 text-dark">
            <input type="text" class="form-control rounded-pill" id="username" name="username" placeholder="Username" required>
            <label for="username">Username</label>
          </div>
          <div class="form-floating mb-4 text-dark">
            <input type="password" class="form-control rounded-pill" id="password" name="password" placeholder="Password" required>
            <label for="password">Password</label>
          </div>
          <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-semibold fs-5" style="background: linear-gradient(45deg, #00c6ff, #0072ff); border: none;">
            Login
          </button>
        </form>
        <p class="mt-4 text-sm text-gray-300">Don't have an account? Ask an Admin to create one.</p>
      </div>
    </div>
    
  </div>
</div>

<%- include('layout/footer') %>
